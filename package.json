{
  "name": "siylo",
  "version": "1.0.0",
  "private": true,
  "description": "Discord-controlled local automation agent built with Electron and Next.js.",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "node scripts/start.mjs",
    "start:renderer": "next start --hostname 127.0.0.1 --port 3000",
    "typecheck": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "discord.js": "^14.19.3",
    "electron": "^35.0.0",
    "next": "^15.2.0",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "screenshot-desktop": "^1.15.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "typescript": "^5.8.2"
  }
}
