{
  "name": "siylo",
  "version": "0.1.0",
  "private": false,
  "description": "Discord-controlled local automation agent built with Electron and Next.js.",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "dist": "npm run build && electron-builder --win nsis",
    "release:win": "npm run build && electron-builder --win nsis --publish always",
    "start": "node scripts/start.mjs",
    "start:renderer": "next start --hostname 127.0.0.1 --port 3000",
    "typecheck": "next typegen && tsc --noEmit"
  },
  "dependencies": {
    "discord.js": "^14.19.3",
    "electron-updater": "^6.8.3",
    "next": "^15.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "screenshot-desktop": "^1.15.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.2"
  },
  "author": "Sxriptor",
  "build": {
    "appId": "com.sxriptor.siylo",
    "productName": "Siylo",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/main/**/*",
      "public/**/*",
      "out/**/*",
      "package.json"
    ],
    "win": {
      "icon": "public/logo.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "siylo-windows.${ext}",
      "executableName": "siylo-windows"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": "always",
      "shortcutName": "Siylo"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Sxriptor",
        "repo": "Siylo",
        "releaseType": "release"
      }
    ]
  }
}
